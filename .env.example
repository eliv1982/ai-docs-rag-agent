OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

PINECONE_API_KEY=
PINECONE_INDEX_NAME=ai-docs-rag-agent
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=1536
PINECONE_METRIC=cosine
PINECONE_CREATE_IF_MISSING=false
PINECONE_SMOKE_NAMESPACE=__smoke_test__
PINECONE_SMOKE_TIMEOUT_SECONDS=30
PINECONE_SMOKE_POLL_INTERVAL_SECONDS=1

URL_FETCH_TIMEOUT_SECONDS=15
URL_MAX_RESPONSE_BYTES=2000000
URL_MAX_REDIRECTS=5
URL_MIN_TEXT_CHARS=200
URL_USER_AGENT=ai-docs-rag-agent/0.1
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

PINECONE_DOCUMENTS_NAMESPACE=documentation
EMBEDDING_BATCH_SIZE=64
PINECONE_UPSERT_BATCH_SIZE=100
PINECONE_FETCH_BATCH_SIZE=500
PINECONE_INDEX_VERIFY_TIMEOUT_SECONDS=30
PINECONE_INDEX_VERIFY_POLL_INTERVAL_SECONDS=1
PINECONE_REPLACE_OLD_SOURCE_VERSIONS=true

RETRIEVAL_TOP_K=5
PYPI_BASE_URL=https://pypi.org
PYPI_TIMEOUT_SECONDS=10

TELEGRAM_BOT_TOKEN=

# Long-term user memory (Stage 4H). USER_MEMORY_HASH_SECRET is a dedicated
# pepper for HMAC-SHA256 pseudonymous identity: set a long random value and
# never reuse another API key/token. Rotating it makes previously written
# memory unreachable through the new identity.
USER_MEMORY_HASH_SECRET=
USER_MEMORY_NAMESPACE_PREFIX=user-memory
USER_MEMORY_TOP_K=5
USER_MEMORY_SCORE_THRESHOLD=0.35
USER_MEMORY_MAX_STATEMENT_LENGTH=500
